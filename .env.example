# ─── Discord Bot ─────────────────────────────────────────────────────────────
# Get from: https://discord.com/developers/applications
BOT_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_bot_client_id_here

# ─── Optional: Genius API (for lyrics) ───────────────────────────────────────
# Get from: https://genius.com/api-clients
# Without this token, lyrics still work but with rate limits
GENIUS_TOKEN=your_genius_api_token_here

# ─── Optional: Spotify (better playlist support) ─────────────────────────────
# Get from: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# ─── Optional: ffmpeg path ────────────────────────────────────────────────────
# Leave empty to use system ffmpeg. Set this if ffmpeg isn't in PATH.
# FFMPEG_PATH=/usr/bin/ffmpeg
